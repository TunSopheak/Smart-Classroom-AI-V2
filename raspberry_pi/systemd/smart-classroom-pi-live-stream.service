[Unit]
Description=Smart Classroom Raspberry Pi Live Stream
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=sopheak
WorkingDirectory=/home/sopheak/Smart-Classroom-AI-V2
Environment=SMART_CLASSROOM_LIVE_STREAM_HOST=0.0.0.0
Environment=SMART_CLASSROOM_LIVE_STREAM_PORT=8081
Environment=SMART_CLASSROOM_LIVE_STREAM_WIDTH=640
Environment=SMART_CLASSROOM_LIVE_STREAM_HEIGHT=480
Environment=SMART_CLASSROOM_LIVE_STREAM_FPS=10
Environment=SMART_CLASSROOM_LIVE_STREAM_JPEG_QUALITY=70
Environment=SMART_CLASSROOM_BACKEND_URL=http://10.86.94.199:8000
Environment=SMART_CLASSROOM_LIVE_SNAPSHOT_UPLOAD_ENABLED=1
Environment=SMART_CLASSROOM_LIVE_SNAPSHOT_UPLOAD_INTERVAL=10
Environment="SMART_CLASSROOM_LIVE_SNAPSHOT_DEVICE_NAME=Raspberry Pi 5 Live Stream"
Environment=SMART_CLASSROOM_LIVE_SNAPSHOT_AUTO_ANALYZE=false
Environment=SMART_CLASSROOM_LIVE_SNAPSHOT_SESSION_ID=11
Environment=SMART_CLASSROOM_LIVE_SNAPSHOT_TIMEOUT=10
ExecStart=/usr/bin/python3 /home/sopheak/Smart-Classroom-AI-V2/raspberry_pi/pi_live_stream.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
